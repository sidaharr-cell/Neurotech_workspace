# ─── Frontend (Vite) ────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Variables prefixed with VITE_ are bundled into the browser build.

# Supabase — from Project Settings → API in the Supabase dashboard
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# ─── Scripts (Node.js only — NOT prefixed with VITE_) ───────────────────────
# These are used by refresh.js and seed.js and should NEVER be in the browser.
# Add these as GitHub Actions Secrets and Vercel environment variables.

# Supabase service role key (has write access — keep secret)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# NewsAPI — https://newsapi.org/ (free account, 100 req/day)
NEWS_API_KEY=your_newsapi_key_here
